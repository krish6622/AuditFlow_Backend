# =========================================================================
# Elangovan Associates — Backend environment configuration
# Copy to `.env` and fill in real values. NEVER commit the real .env file.
# =========================================================================

# ---- Application ----
APP_NAME="Elangovan Associates"
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database (Neon / local Postgres) ----
# Local example:   postgresql+psycopg://postgres:postgres@localhost:5432/elangovan
# Neon example:    postgresql+psycopg://USER:PASSWORD@ep-xxx.neon.tech/elangovan?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elangovan

# ---- JWT / Security ----
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# ---- Initial Super Admin (seeded by `python -m app.cli seed-superadmin`) ----
SUPERADMIN_EMAIL=admin@keplercrew.com
SUPERADMIN_PASSWORD=ChangeMe!2026

# ---- Cloudflare R2 (file storage — used from Work Order attachments phase) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=elangovan-files
R2_PUBLIC_BASE_URL=
